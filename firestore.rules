rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Events: anyone can read (for polls/invites), authenticated users can write
    // Unauthenticated users can update (for poll RSVP/voting member registration)
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;
      allow delete: if request.auth != null;

      // Date options: anyone can read and vote (for unauthenticated poll participants)
      match /dateOptions/{optionId} {
        allow read, write: if true;
      }

      // Chat: authenticated users only
      match /chat/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Users: only the owner can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Friends subcollection
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
